<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Darkroom</title>
<link rel="stylesheet" href="/css/main.css">
</head>
<body class="app-body">
<div class="topbar">
  <div class="topbar-logo">dark<span>room</span></div>
  <div class="topbar-right">
    <span class="user-chip">👤 <%= userName %></span>
    <a href="/logout" class="btn-ghost">Sair</a>
  </div>
</div>
<div class="layout">
  <aside class="sidebar">
    <a href="/dashboard" class="sidebar-item active">🎬 Modelos</a>
    <a href="/logout" class="sidebar-item">↩ Sair</a>
  </aside>
  <main class="content">
    <div class="page-header">
      <div>
        <h1 class="page-title">🎬 Modelos</h1>
        <p class="page-sub">Gerencie modelos, tipos de chamada e links para clientes</p>
        <div class="page-meta">
          <span><b><%= stats.totalModels %></b> modelos</span>
          <span>•</span>
          <span><b><%= stats.totalCallTypes %></b> tipos de chamada</span>
          <span>•</span>
          <span><b><%= stats.activeSessions %></b> sessões ativas</span>
        </div>
      </div>
      <button class="btn-orange" id="btn-novo-modelo">+ Novo Modelo</button>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-label">Modelos</div>
        <div class="stat-value orange"><%= stats.totalModels %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Tipos de Chamada</div>
        <div class="stat-value"><%= stats.totalCallTypes %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Ao Vivo Agora</div>
        <div class="stat-value green"><%= stats.activeSessions %></div>
      </div>
    </div>

    <div class="links-list" id="models-list">
      <% models.forEach(function(model) { %>
      <div class="link-card" id="model-<%= model.id %>">
        <div class="link-card-header">
          <div class="host-info">
            <div class="avatar" style="background:<%= model.avatar_color %>"><%= model.name.substring(0,2).toUpperCase() %></div>
            <div>
              <div class="host-name"><%= model.name %></div>
              <div class="host-slug">
                <span class="badge <%= model.active ? 'badge-active' : 'badge-inactive' %>">
                  <%= model.active ? 'Ativa' : 'Inativa' %>
                </span>
                <span style="margin-left:8px;font-size:12px;color:#888"><%= model.callTypes.length %> tipos de chamada</span>
              </div>
            </div>
          </div>
          <div class="link-actions">
            <button class="btn-icon" data-add-calltype="<%= model.id %>" data-model-name="<%= model.name %>">+ Chamada</button>
            <button class="btn-icon" data-edit-model="<%= model.id %>" data-name="<%= model.name %>">✏️</button>
            <button class="btn-icon danger" data-delete-model="<%= model.id %>">🗑️</button>
          </div>
        </div>

        <% if (model.callTypes.length > 0) { %>
        <div class="sessions-panel" style="display:block; padding: 0 16px 16px">
          <% model.callTypes.forEach(function(ct) { %>
          <div class="calltype-row" id="ct-<%= ct.id %>">
            <div class="calltype-info">
              <span class="calltype-name"><%= ct.name %></span>
              <% if (ct.video_url) { %>
                <span class="badge badge-active" style="font-size:10px">✓ Vídeo</span>
              <% } else { %>
                <span class="badge badge-inactive" style="font-size:10px">Sem vídeo</span>
              <% } %>
              <span style="font-size:11px;color:#888"><%= ct.totalSessions %> sessões</span>
            </div>
            <div class="link-actions">
              <button class="btn-icon orange" data-share-ct="<%= ct.id %>">🔗 Link</button>
              <button class="btn-icon" data-edit-ct="<%= ct.id %>" data-name="<%= ct.name %>">✏️</button>
              <button class="btn-icon danger" data-delete-ct="<%= ct.id %>">🗑️</button>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% }) %>

      <% if (models.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">🎬</div>
        <p>Nenhum modelo cadastrado ainda</p>
        <button class="btn-orange" id="btn-primeiro-modelo">Criar primeiro modelo</button>
      </div>
      <% } %>
    </div>
  </main>
</div>

<!-- Modal Novo Modelo -->
<div class="modal-overlay" id="modal-novo-modelo">
  <div class="modal">
    <div class="modal-header">
      <h2>🎬 Novo Modelo</h2>
      <button class="modal-close" id="btn-close-modelo">✕</button>
    </div>
    <form id="form-novo-modelo">
      <div class="field">
        <label>Nome da Modelo *</label>
        <input type="text" id="modelo-nome" placeholder="Ex: Thamara" required>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost" id="btn-cancel-modelo">Cancelar</button>
        <button type="submit" class="btn-orange">Criar Modelo</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Editar Modelo -->
<div class="modal-overlay" id="modal-edit-modelo">
  <div class="modal">
    <div class="modal-header">
      <h2>✏️ Editar Modelo</h2>
      <button class="modal-close" id="btn-close-edit-modelo">✕</button>
    </div>
    <form id="form-edit-modelo">
      <input type="hidden" id="edit-modelo-id">
      <div class="field">
        <label>Nome da Modelo *</label>
        <input type="text" id="edit-modelo-nome" placeholder="Ex: Thamara" required>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost" id="btn-cancel-edit-modelo">Cancelar</button>
        <button type="submit" class="btn-orange">Salvar</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Novo Tipo de Chamada -->
<div class="modal-overlay" id="modal-novo-ct">
  <div class="modal">
    <div class="modal-header">
      <h2>📞 Novo Tipo de Chamada</h2>
      <button class="modal-close" id="btn-close-ct">✕</button>
    </div>
    <form id="form-novo-ct">
      <input type="hidden" id="ct-model-id">
      <div class="field">
        <label>Nome do Tipo *</label>
        <input type="text" id="ct-nome" placeholder="Ex: 3min Normal" required>
      </div>
      <div class="field">
        <label>Vídeo</label>
        <div class="upload-zone" id="upload-zone-ct">
          <div class="upload-icon">🎬</div>
          <div id="upload-label-ct">Clique para adicionar vídeo</div>
          <div class="upload-sub">MP4, MOV, WebM • Máximo 500MB</div>
        </div>
        <input type="file" id="video-input-ct" accept="video/*" style="display:none">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost" id="btn-cancel-ct">Cancelar</button>
        <button type="submit" class="btn-orange" id="btn-create-ct">Criar Tipo</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Editar Tipo de Chamada -->
<div class="modal-overlay" id="modal-edit-ct">
  <div class="modal">
    <div class="modal-header">
      <h2>✏️ Editar Tipo de Chamada</h2>
      <button class="modal-close" id="btn-close-edit-ct">✕</button>
    </div>
    <form id="form-edit-ct">
      <input type="hidden" id="edit-ct-id">
      <div class="field">
        <label>Nome do Tipo *</label>
        <input type="text" id="edit-ct-nome" placeholder="Ex: 3min Normal" required>
      </div>
      <div class="field">
        <label>Trocar Vídeo (opcional)</label>
        <div class="upload-zone" id="upload-zone-edit-ct">
          <div class="upload-icon">🎬</div>
          <div id="upload-label-edit-ct">Clique para trocar o vídeo</div>
          <div class="upload-sub">MP4, MOV, WebM • Máximo 500MB</div>
        </div>
        <input type="file" id="video-input-edit-ct" accept="video/*" style="display:none">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost" id="btn-cancel-edit-ct">Cancelar</button>
        <button type="submit" class="btn-orange" id="btn-save-edit-ct">Salvar</button>
      </div>
    </form>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
var BASE_URL = '<%= baseUrl %>';

function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 3000);
}

// --- Modais Modelo ---
function showModalModelo() { document.getElementById('modal-novo-modelo').classList.add('open'); }
function hideModalModelo() { document.getElementById('modal-novo-modelo').classList.remove('open'); }
function showEditModalModelo() { document.getElementById('modal-edit-modelo').classList.add('open'); }
function hideEditModalModelo() { document.getElementById('modal-edit-modelo').classList.remove('open'); }

// --- Modais CallType ---
function showModalCt() { document.getElementById('modal-novo-ct').classList.add('open'); }
function hideModalCt() { document.getElementById('modal-novo-ct').classList.remove('open'); }
function showEditModalCt() { document.getElementById('modal-edit-ct').classList.add('open'); }
function hideEditModalCt() { document.getElementById('modal-edit-ct').classList.remove('open'); }

document.getElementById('btn-novo-modelo').addEventListener('click', showModalModelo);
var btnPrimeiro = document.getElementById('btn-primeiro-modelo');
if (btnPrimeiro) btnPrimeiro.addEventListener('click', showModalModelo);
document.getElementById('btn-close-modelo').addEventListener('click', hideModalModelo);
document.getElementById('btn-cancel-modelo').addEventListener('click', hideModalModelo);
document.getElementById('btn-close-edit-modelo').addEventListener('click', hideEditModalModelo);
document.getElementById('btn-cancel-edit-modelo').addEventListener('click', hideEditModalModelo);
document.getElementById('btn-close-ct').addEventListener('click', hideModalCt);
document.getElementById('btn-cancel-ct').addEventListener('click', hideModalCt);
document.getElementById('btn-close-edit-ct').addEventListener('click', hideEditModalCt);
document.getElementById('btn-cancel-edit-ct').addEventListener('click', hideEditModalCt);

// Upload zones
document.getElementById('upload-zone-ct').addEventListener('click', function() {
  document.getElementById('video-input-ct').click();
});
document.getElementById('video-input-ct').addEventListener('change', function() {
  if (this.files[0]) document.getElementById('upload-label-ct').textContent = '✓ ' + this.files[0].name;
});
document.getElementById('upload-zone-edit-ct').addEventListener('click', function() {
  document.getElementById('video-input-edit-ct').click();
});
document.getElementById('video-input-edit-ct').addEventListener('change', function() {
  if (this.files[0]) document.getElementById('upload-label-edit-ct').textContent = '✓ ' + this.files[0].name;
});

// Upload direto ao Cloudinary
async function uploadVideo(file, btnEl, labelEl) {
  var cloudForm = new FormData();
  cloudForm.append('file', file);
  cloudForm.append('upload_preset', 'darkroom_videos');

  return new Promise(function(resolve, reject) {
    var xhr = new XMLHttpRequest();
    xhr.upload.addEventListener('progress', function(ev) {
      if (ev.lengthComputable) {
        var pct = Math.round((ev.loaded / ev.total) * 100);
        if (btnEl) btnEl.textContent = 'Enviando... ' + pct + '%';
        if (labelEl) labelEl.textContent = 'Enviando... ' + pct + '%';
      }
    });
    xhr.addEventListener('load', function() {
      if (xhr.status === 200) {
        var result = JSON.parse(xhr.responseText);
        resolve({ url: result.secure_url, public_id: result.public_id });
      } else {
        reject(new Error('Erro Cloudinary ' + xhr.status + ': ' + xhr.responseText));
      }
    });
    xhr.addEventListener('error', function() { reject(new Error('Falha de rede')); });
    xhr.open('POST', 'https://api.cloudinary.com/v1_1/di0u5vsaq/video/upload');
    xhr.send(cloudForm);
  });
}

// --- Form Novo Modelo ---
document.getElementById('form-novo-modelo').addEventListener('submit', async function(e) {
  e.preventDefault();
  var nome = document.getElementById('modelo-nome').value;
  try {
    var r = await fetch('/links/model/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: nome })
    });
    var data = await r.json();
    if (data.success) { showToast('Modelo criado!'); setTimeout(function(){ location.reload(); }, 1000); }
    else { showToast('Erro: ' + (data.error || 'Tente novamente')); }
  } catch(err) { showToast('Erro de conexão'); }
});

// --- Form Editar Modelo ---
document.getElementById('form-edit-modelo').addEventListener('submit', async function(e) {
  e.preventDefault();
  var id = document.getElementById('edit-modelo-id').value;
  var nome = document.getElementById('edit-modelo-nome').value;
  try {
    var r = await fetch('/links/model/edit/' + id, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: nome })
    });
    var data = await r.json();
    if (data.success) { showToast('Modelo atualizado!'); setTimeout(function(){ location.reload(); }, 1000); }
    else { showToast('Erro: ' + (data.error || 'Tente novamente')); }
  } catch(err) { showToast('Erro de conexão'); }
});

// --- Form Novo Tipo de Chamada ---
document.getElementById('form-novo-ct').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('btn-create-ct');
  var modelId = document.getElementById('ct-model-id').value;
  var nome = document.getElementById('ct-nome').value;
  var videoFile = document.getElementById('video-input-ct').files[0];
  var labelEl = document.getElementById('upload-label-ct');

  btn.disabled = true;
  btn.textContent = 'Salvando...';

  try {
    var videoUrl = null, publicId = null;
    if (videoFile) {
      var uploaded = await uploadVideo(videoFile, btn, labelEl);
      videoUrl = uploaded.url;
      publicId = uploaded.public_id;
    }
    var r = await fetch('/links/calltype/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model_id: modelId, name: nome, video_url: videoUrl, video_public_id: publicId })
    });
    var data = await r.json();
    if (data.success) { showToast('Tipo criado!'); setTimeout(function(){ location.reload(); }, 1000); }
    else { showToast('Erro: ' + (data.error || 'Tente novamente')); }
  } catch(err) {
    showToast('Erro: ' + err.message);
  } finally {
    btn.disabled = false;
    btn.textContent = 'Criar Tipo';
  }
});

// --- Form Editar Tipo de Chamada ---
document.getElementById('form-edit-ct').addEventListener('submit', async function(e) {
  e.preventDefault();
  var btn = document.getElementById('btn-save-edit-ct');
  var id = document.getElementById('edit-ct-id').value;
  var nome = document.getElementById('edit-ct-nome').value;
  var videoFile = document.getElementById('video-input-edit-ct').files[0];
  var labelEl = document.getElementById('upload-label-edit-ct');

  btn.disabled = true;
  btn.textContent = 'Salvando...';

  try {
    var videoUrl = null, publicId = null;
    if (videoFile) {
      var uploaded = await uploadVideo(videoFile, btn, labelEl);
      videoUrl = uploaded.url;
      publicId = uploaded.public_id;
    }
    var r = await fetch('/links/calltype/edit/' + id, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: nome, video_url: videoUrl, video_public_id: publicId })
    });
    var data = await r.json();
    if (data.success) { showToast('Tipo atualizado!'); setTimeout(function(){ location.reload(); }, 1000); }
    else { showToast('Erro: ' + (data.error || 'Tente novamente')); }
  } catch(err) {
    showToast('Erro: ' + err.message);
  } finally {
    btn.disabled = false;
    btn.textContent = 'Salvar';
  }
});

// --- Delegação de eventos ---
document.addEventListener('click', async function(e) {
  var addCt = e.target.getAttribute('data-add-calltype');
  var editModel = e.target.getAttribute('data-edit-model');
  var deleteModel = e.target.getAttribute('data-delete-model');
  var shareCt = e.target.getAttribute('data-share-ct');
  var editCt = e.target.getAttribute('data-edit-ct');
  var deleteCt = e.target.getAttribute('data-delete-ct');

  if (addCt) {
    document.getElementById('ct-model-id').value = addCt;
    document.getElementById('ct-nome').value = '';
    document.getElementById('upload-label-ct').textContent = 'Clique para adicionar vídeo';
    document.getElementById('btn-create-ct').textContent = 'Criar Tipo';
    document.getElementById('btn-create-ct').disabled = false;
    showModalCt();
  }

  if (editModel) {
    var nome = e.target.getAttribute('data-name');
    document.getElementById('edit-modelo-id').value = editModel;
    document.getElementById('edit-modelo-nome').value = nome;
    showEditModalModelo();
  }

  if (deleteModel) {
    if (confirm('Deletar este modelo e todos os seus tipos de chamada?')) {
      var r = await fetch('/links/model/delete/' + deleteModel, { method: 'DELETE' });
      var data = await r.json();
      if (data.success) { showToast('Modelo deletado!'); location.reload(); }
      else { showToast('Erro ao deletar'); }
    }
  }

  if (shareCt) {
    var r = await fetch('/links/share/' + shareCt, { method: 'POST' });
    var data = await r.json();
    if (data.success) {
      navigator.clipboard.writeText(data.url).catch(function(){});
      showToast('Link copiado: ' + data.url);
    } else {
      showToast('Erro: ' + (data.error || 'Tente novamente'));
    }
  }

  if (editCt) {
    var nome = e.target.getAttribute('data-name');
    document.getElementById('edit-ct-id').value = editCt;
    document.getElementById('edit-ct-nome').value = nome;
    document.getElementById('upload-label-edit-ct').textContent = 'Clique para trocar o vídeo';
    document.getElementById('btn-save-edit-ct').textContent = 'Salvar';
    document.getElementById('btn-save-edit-ct').disabled = false;
    showEditModalCt();
  }

  if (deleteCt) {
    if (confirm('Deletar este tipo de chamada?')) {
      var r = await fetch('/links/calltype/delete/' + deleteCt, { method: 'DELETE' });
      var data = await r.json();
      if (data.success) { showToast('Tipo deletado!'); location.reload(); }
      else { showToast('Erro ao deletar'); }
    }
  }
});
</script>

<style>
.calltype-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  background: rgba(255,255,255,0.03);
  border-radius: 8px;
  margin-bottom: 8px;
  border: 1px solid rgba(255,255,255,0.06);
}
.calltype-info {
  display: flex;
  align-items: center;
  gap: 10px;
}
.calltype-name {
  font-size: 14px;
  font-weight: 500;
  color: #e0e0e0;
}
</style>
</body>
</html>
