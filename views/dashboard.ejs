<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Darkroom</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="stylesheet" href="/css/main.css">
</head>
<body class="app-body">
<div class="topbar">
  <div class="topbar-logo">dark<span>room</span></div>
  <div class="topbar-right">
    <span class="user-chip">👤 <%= userName %></span>
    <a href="/logout" class="btn-ghost">Sair</a>
  </div>
</div>
<div class="layout">
  <aside class="sidebar">
    <a href="/dashboard" class="sidebar-item active">⬛ Modelos</a>
    <a href="/logout" class="sidebar-item">↩ Sair</a>
  </aside>
  <main class="content">
    <div class="page-header">
      <div>
        <h1 class="page-title">⬛ Modelos</h1>
        <div class="page-meta">
          <span><b><%= stats.totalModels %></b> modelos</span>
          <span>•</span>
          <span><b><%= stats.totalCallTypes %></b> tipos de chamada</span>
          <span>•</span>
          <span><b><%= stats.activeSessions %></b> ao vivo agora</span>
        </div>
      </div>
      <button class="btn-orange" id="btn-nova-modelo">+ Nova Modelo</button>
    </div>

    <div class="models-grid" id="models-grid">
      <% models.forEach(function(model) { %>
      <div class="model-card" id="model-<%= model.id %>">
        <div class="model-header">
          <div class="model-avatar" style="background:<%= model.avatar_color %>">
            <%= model.name.substring(0,2).toUpperCase() %>
          </div>
          <div class="model-info">
            <div class="model-name"><%= model.name %></div>
            <div class="model-stats"><%= model.callTypes.length %> tipos de chamada</div>
          </div>
          <div class="model-actions">
            <button class="btn-icon" data-edit-model="<%= model.id %>" data-name="<%= model.name %>">✏️</button>
            <button class="btn-icon danger" data-delete-model="<%= model.id %>">🗑️</button>
          </div>
        </div>

        <div class="calltypes-list">
          <% model.callTypes.forEach(function(ct) { %>
          <div class="calltype-row" id="ct-<%= ct.id %>">
            <div class="calltype-name"><%= ct.name %></div>
            <div class="calltype-actions">
              <button class="btn-share" data-share="<%= ct.id %>" title="Gerar link">+</button>
              <input type="text" class="link-field" id="link-<%= ct.id %>" placeholder="Link gerado aqui..." readonly>
              <button class="btn-copy" data-copy="<%= ct.id %>" title="Copiar">⎘</button>
              <button class="btn-history" data-history="<%= ct.id %>" title="Histórico">▾</button>
              <button class="btn-icon" data-edit-ct="<%= ct.id %>" data-ct-name="<%= ct.name %>">✏️</button>
              <button class="btn-icon danger" data-delete-ct="<%= ct.id %>">🗑️</button>
            </div>
            <div class="history-panel" id="history-<%= ct.id %>" style="display:none"></div>
          </div>
          <% }) %>
        </div>

        <button class="btn-add-calltype" data-model-id="<%= model.id %>">+ Adicionar tipo de chamada</button>
      </div>
      <% }) %>

      <div class="model-card model-card-new" id="btn-nova-modelo-card">
        <div class="new-model-inner">
          <div class="new-model-icon">+</div>
          <div>Nova Modelo</div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Modal nova/editar modelo -->
<div class="modal-overlay" id="modal-model">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modal-model-title">Nova Modelo</h2>
      <button class="modal-close" id="btn-close-model-modal">✕</button>
    </div>
    <form id="form-model">
      <input type="hidden" id="model-id">
      <div class="field">
        <label>Nome da Modelo *</label>
        <input type="text" id="model-name" placeholder="Ex: Bruna" required>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost" id="btn-cancel-model">Cancelar</button>
        <button type="submit" class="btn-orange" id="btn-save-model">Criar Modelo</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal novo/editar tipo de chamada -->
<div class="modal-overlay" id="modal-calltype">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modal-ct-title">Novo Tipo de Chamada</h2>
      <button class="modal-close" id="btn-close-ct-modal">✕</button>
    </div>
    <p class="modal-sub">Ex: 3min Normal, 5min Fetiche Podo, 10min Lésbico</p>
    <form id="form-calltype" enctype="multipart/form-data">
      <input type="hidden" id="ct-model-id">
      <input type="hidden" id="ct-id">
      <div class="field">
        <label>Nome do Tipo *</label>
        <input type="text" id="ct-name" placeholder="Ex: 3min Normal" required>
      </div>
      <div class="field">
        <label>Vídeo <span id="video-label-hint">(obrigatório para novo)</span></label>
        <div class="upload-zone" id="ct-upload-zone">
          <div class="upload-icon">🎬</div>
          <div id="ct-upload-label">Clique para adicionar vídeo</div>
          <div class="upload-sub">MP4, MOV, AVI, MKV, WebM • Máximo 500MB</div>
        </div>
        <input type="file" name="video" id="ct-video-input" accept="video/*" style="display:none">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost" id="btn-cancel-ct">Cancelar</button>
        <button type="submit" class="btn-orange" id="btn-save-ct">Salvar</button>
      </div>
    </form>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
var BASE_URL = '<%= baseUrl %>';

function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 3000);
}

function showModal(id) { document.getElementById(id).classList.add('open'); }
function hideModal(id) { document.getElementById(id).classList.remove('open'); }

// Abrir modal nova modelo
document.getElementById('btn-nova-modelo').addEventListener('click', function() {
  document.getElementById('modal-model-title').textContent = 'Nova Modelo';
  document.getElementById('model-id').value = '';
  document.getElementById('model-name').value = '';
  document.getElementById('btn-save-model').textContent = 'Criar Modelo';
  showModal('modal-model');
});

document.getElementById('btn-nova-modelo-card').addEventListener('click', function() {
  document.getElementById('btn-nova-modelo').click();
});

document.getElementById('btn-close-model-modal').addEventListener('click', function() { hideModal('modal-model'); });
document.getElementById('btn-cancel-model').addEventListener('click', function() { hideModal('modal-model'); });
document.getElementById('btn-close-ct-modal').addEventListener('click', function() { hideModal('modal-calltype'); });
document.getElementById('btn-cancel-ct').addEventListener('click', function() { hideModal('modal-calltype'); });

document.getElementById('ct-upload-zone').addEventListener('click', function() {
  document.getElementById('ct-video-input').click();
});
document.getElementById('ct-video-input').addEventListener('change', function() {
  if (this.files[0]) document.getElementById('ct-upload-label').textContent = '✓ ' + this.files[0].name;
});

// Salvar modelo
document.getElementById('form-model').addEventListener('submit', async function(e) {
  e.preventDefault();
  var id = document.getElementById('model-id').value;
  var name = document.getElementById('model-name').value;
  var url = id ? '/links/model/edit/' + id : '/links/model/create';
  var r = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name })
  });
  var data = await r.json();
  if (data.success) { showToast(id ? 'Modelo atualizada!' : 'Modelo criada!'); location.reload(); }
  else showToast('Erro: ' + data.error);
});

// Salvar tipo de chamada
document.getElementById('form-calltype').addEventListener('submit', async function(e) {
  e.preventDefault();
  var id = document.getElementById('ct-id').value;
  var btn = document.getElementById('btn-save-ct');
  btn.textContent = 'Enviando...';
  btn.disabled = true;
  var fd = new FormData(this);
  fd.append('name', document.getElementById('ct-name').value);
  fd.append('model_id', document.getElementById('ct-model-id').value);
  var url = id ? '/links/calltype/edit/' + id : '/links/calltype/create';
  try {
    var r = await fetch(url, { method: 'POST', body: fd });
    var data = await r.json();
    if (data.success) { showToast('Salvo com sucesso!'); location.reload(); }
    else { showToast('Erro: ' + data.error); btn.textContent = 'Salvar'; btn.disabled = false; }
  } catch(err) { showToast('Erro de conexão'); btn.textContent = 'Salvar'; btn.disabled = false; }
});

document.addEventListener('click', async function(e) {
  var editModel = e.target.getAttribute('data-edit-model');
  var deleteModel = e.target.getAttribute('data-delete-model');
  var addCt = e.target.getAttribute('data-model-id');
  var editCt = e.target.getAttribute('data-edit-ct');
  var deleteCt = e.target.getAttribute('data-delete-ct');
  var shareId = e.target.getAttribute('data-share');
  var copyId = e.target.getAttribute('data-copy');
  var historyId = e.target.getAttribute('data-history');

  if (editModel) {
    document.getElementById('modal-model-title').textContent = 'Editar Modelo';
    document.getElementById('model-id').value = editModel;
    document.getElementById('model-name').value = e.target.getAttribute('data-name');
    document.getElementById('btn-save-model').textContent = 'Salvar';
    showModal('modal-model');
  }

  if (deleteModel) {
    if (confirm('Deletar esta modelo e todos os seus tipos de chamada?')) {
      var r = await fetch('/links/model/delete/' + deleteModel, { method: 'DELETE' });
      var data = await r.json();
      if (data.success) { showToast('Modelo deletada!'); location.reload(); }
    }
  }

  if (addCt) {
    document.getElementById('modal-ct-title').textContent = 'Novo Tipo de Chamada';
    document.getElementById('ct-model-id').value = addCt;
    document.getElementById('ct-id').value = '';
    document.getElementById('ct-name').value = '';
    document.getElementById('ct-upload-label').textContent = 'Clique para adicionar vídeo';
    document.getElementById('video-label-hint').textContent = '(obrigatório para novo)';
    document.getElementById('ct-video-input').value = '';
    showModal('modal-calltype');
  }

  if (editCt) {
    document.getElementById('modal-ct-title').textContent = 'Editar Tipo de Chamada';
    document.getElementById('ct-id').value = editCt;
    document.getElementById('ct-name').value = e.target.getAttribute('data-ct-name');
    document.getElementById('video-label-hint').textContent = '(opcional — só se quiser trocar)';
    document.getElementById('ct-upload-label').textContent = 'Clique para trocar o vídeo';
    showModal('modal-calltype');
  }

  if (deleteCt) {
    if (confirm('Deletar este tipo de chamada?')) {
      var r = await fetch('/links/calltype/delete/' + deleteCt, { method: 'DELETE' });
      var data = await r.json();
      if (data.success) { showToast('Tipo deletado!'); location.reload(); }
    }
  }

  if (shareId) {
    var r = await fetch('/links/share/' + shareId, { method: 'POST' });
    var data = await r.json();
    if (data.success) {
      var field = document.getElementById('link-' + shareId);
      if (field) field.value = data.url;
      navigator.clipboard.writeText(data.url).catch(function(){});
      showToast('Link gerado e copiado!');
    } else {
      showToast('Erro: ' + (data.error || 'Tente novamente'));
    }
  }

  if (copyId) {
    var field = document.getElementById('link-' + copyId);
    if (field && field.value) {
      navigator.clipboard.writeText(field.value).catch(function(){});
      showToast('Link copiado!');
    } else {
      showToast('Gere um link primeiro clicando em +');
    }
  }

  if (historyId) {
    var panel = document.getElementById('history-' + historyId);
    if (panel.style.display === 'none') {
      panel.style.display = 'block';
      var r = await fetch('/dashboard/calltype/' + historyId + '/sessions');
      var sessions = await r.json();
      if (sessions.length === 0) {
        panel.innerHTML = '<div class="history-empty">Nenhuma sessão ainda</div>';
        return;
      }
      var html = '<table class="history-table"><thead><tr><th>Status</th><th>Criado em</th><th>Duração</th></tr></thead><tbody>';
      sessions.forEach(function(s) {
        var badge = s.status === 'active' ? 'badge-active' : s.status === 'ended' ? 'badge-ended' : 'badge-pending';
        var label = s.status === 'active' ? '● Ativa' : s.status === 'ended' ? '⊘ Finalizada' : '○ Pendente';
        var dur = s.duration_mins ? s.duration_mins + ' min' : '—';
        html += '<tr><td><span class="badge ' + badge + '">' + label + '</span></td><td>' + new Date(s.created_at).toLocaleString('pt-BR') + '</td><td>' + dur + '</td></tr>';
      });
      html += '</tbody></table>';
      panel.innerHTML = html;
    } else {
      panel.style.display = 'none';
    }
  }
});
</script>
</body>
</html>
