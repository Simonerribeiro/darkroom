<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Darkroom — Login</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="stylesheet" href="/css/main.css">
</head>
<body class="auth-body">
<div class="auth-container">
  <div class="auth-box">
    <div class="logo">dark<span>room</span></div>
    <p class="auth-sub">Plataforma de videochamadas privadas</p>

    <!-- Logo BelleVue -->
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin:12px 0 20px;">
      <svg width="36" height="36" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="46" fill="none" stroke="#555" stroke-width="3"/>
        <line x1="50" y1="4" x2="50" y2="20" stroke="#555" stroke-width="2"/>
        <line x1="50" y1="80" x2="50" y2="96" stroke="#555" stroke-width="2"/>
        <path d="M50 15 Q58 30 50 50 Q42 70 50 85" fill="#333" stroke="#555" stroke-width="1"/>
        <path d="M50 25 Q65 40 62 55 Q58 68 50 78" fill="#333" stroke="none"/>
        <path d="M50 25 Q35 40 38 55 Q42 68 50 78" fill="#222" stroke="none"/>
        <rect x="18" y="38" width="14" height="22" rx="2" fill="#4a3f6b" opacity="0.9"/>
        <rect x="22" y="42" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
        <rect x="22" y="48" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
        <rect x="27" y="42" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
        <rect x="27" y="48" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
        <rect x="68" y="38" width="14" height="22" rx="2" fill="#4a3f6b" opacity="0.9"/>
        <rect x="72" y="42" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
        <rect x="72" y="48" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
        <rect x="77" y="42" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
        <rect x="77" y="48" width="3" height="3" fill="#c8a84b" opacity="0.8"/>
      </svg>
      <span style="font-family:Arial,sans-serif;font-size:16px;font-weight:600;color:#cccccc;letter-spacing:1px;">BelleVue</span>
    </div>

    <% if (error) { %>
    <div class="alert-error"><%= error %></div>
    <% } %>
    <form action="/login" method="POST">
      <div class="field">
        <label>Email</label>
        <input type="email" name="email" placeholder="seu@email.com" required>
      </div>
      <div class="field">
        <label>Senha</label>
        <input type="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn-primary full">Entrar</button>
    </form>
  </div>
</div>
</body>
</html>
